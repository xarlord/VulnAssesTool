# Environment Variables for VulnAssessTool Build & Release
# Copy this file to .env and fill in the values
# DO NOT commit .env file to version control

# ============================================================================
# Application Configuration
# ============================================================================

# Node environment (development, production, test)
NODE_ENV=development

# Enable DevTools in production (only for debugging)
E2E_NO_DEVTOOLS=false

# ============================================================================
# Windows Code Signing
# ============================================================================

# Path to Windows code signing certificate (PFX/P12 file)
# For local builds: Use absolute file path
# For CI/CD: Use base64-encoded certificate content
WIN_CSC_LINK=

# Password for the Windows certificate
WIN_CSC_KEY_PASSWORD=

# ============================================================================
# macOS Code Signing & Notarization
# ============================================================================

# Your Apple ID email address
APPLE_ID=

# App-specific password for notarization
# Generate at: https://appleid.apple.com
APPLE_ID_PASSWORD=

# Your Apple Developer Team ID
# Find with: security find-identity -v -p codesigning
APPLE_TEAM_ID=

# Base64-encoded macOS code signing certificate (P12 file)
# Generate with: base64 -i certificate.p12 | pbcopy
MAC_CERTS=

# Password for the P12 file
MAC_CERTS_PASSWORD=

# Password for temporary keychain (used during CI build)
KEYCHAIN_PASSWORD=

# ============================================================================
# GitHub Configuration
# ============================================================================

# GitHub token for creating releases
# In CI/CD, this is automatically provided as GITHUB_TOKEN
# For local testing, use a personal access token with repo scope
GITHUB_TOKEN=

# Repository owner/username
GITHUB_OWNER=vulnasstool

# Repository name
GITHUB_REPO=vuln-asses-tool

# ============================================================================
# Build Configuration
# ============================================================================

# Electron builder configuration
# Build output directory
BUILD_OUTPUT_DIR=release

# Build resources directory
BUILD_RESOURCES_DIR=build

# ============================================================================
# Testing Configuration
# ============================================================================

# Enable test coverage reporting
VITEST_COVERAGE=true

# Coverage threshold (percentage)
COVERAGE_THRESHOLD=95

# ============================================================================
# API Configuration (Optional)
# ============================================================================

# NVD API Key (optional but recommended for higher rate limits)
# Get free key from: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# OSV API Key (optional)
# Currently OSV doesn't require an API key
OSV_API_KEY=

# ============================================================================
# Electron-Updater Configuration
# ============================================================================

# Update feed provider (github, s3, generic, etc.)
UPDATE_FEED_PROVIDER=github

# Enable automatic download of updates
UPDATE_AUTO_DOWNLOAD=true

# Enable automatic installation on quit
UPDATE_AUTO_INSTALL_ON_QUIT=true

# ============================================================================
# Logging Configuration
# ============================================================================

# Log level (error, warn, info, debug, trace)
LOG_LEVEL=info

# Enable file logging
LOG_TO_FILE=true

# Log directory
LOG_DIR=logs

# ============================================================================
# Development Configuration
# ============================================================================

# Vite dev server port
VITE_DEV_SERVER_PORT=3000

# Enable hot module replacement
VITE_HMR=true

# E2E test URL (for Playwright testing)
E2E_TEST_URL=

# ============================================================================
# Database Configuration
# ============================================================================

# Database sync on startup
DATABASE_SYNC_ON_STARTUP=false

# NVD data years to sync (comma-separated)
NVD_SYNC_YEARS=2021,2022,2023,2024,2025,2026

# ============================================================================
# Watchdog AI Fix Configuration
# ============================================================================

# GLM API Key for Watchdog autonomous testing auto-fix
# Get your key from: https://open.bigmodel.cn/
GLM_API_KEY=

# GLM API Base URL (default: https://open.bigmodel.cn/api/paas/v4)
GLM_API_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# GLM Model for auto-fix (default: glm-5)
GLM_MODEL=glm-5

# ============================================================================
# Analytics & Error Reporting (Optional)
# ============================================================================

# Sentry DSN for error tracking
SENTRY_DSN=

# Enable analytics
ANALYTICS_ENABLED=false

# Analytics provider
ANALYTICS_PROVIDER=

# ============================================================================
# Feature Flags
# ============================================================================

# Enable experimental features
FEATURE_EXPERIMENTAL=false

# Enable beta features
FEATURE_BETA=false

# Enable debug mode
DEBUG=false
