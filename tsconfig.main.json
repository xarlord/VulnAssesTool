{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.main.tsbuildinfo",
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "CommonJS",
    "types": ["node"],
    "skipLibCheck": true,

    /* Module resolution */
    "moduleResolution": "node",
    "moduleDetection": "force",
    "outDir": "dist/electron",
    "rootDir": "electron",

    /* Output format */
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    /* Path Aliases */
    "baseUrl": ".",
    "paths": {
      "@@/*": ["./src/shared/*"]
    },

    /* Linting */
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["electron/**/*.ts", "src/main/**/*.ts"],
  "exclude": ["electron/**/*.test.ts", "electron/preload.ts", "node_modules"]
}
